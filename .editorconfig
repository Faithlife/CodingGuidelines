root = true

# DO NOT EDIT: root convention
[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
# END DO NOT EDIT

[*.{yml,yaml}]
indent_size = 2
indent_style = space

[*.md]
indent_size = 2
indent_style = space

[*.ps1]
indent_size = tab
indent_style = tab
tab_width = 4

[*.cs]
indent_size = tab
indent_style = tab
tab_width = 4
csharp_indent_block_contents = true
