root = true

# DO NOT EDIT: root convention
[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
# END DO NOT EDIT

[*.cs]
indent_size = tab
indent_style = tab
tab_width = 4
csharp_indent_block_contents = true

# DO NOT EDIT: json convention
[*.json]
indent_size = 2
indent_style = space
# END DO NOT EDIT

# DO NOT EDIT: md convention
[*.md]
indent_size = 2
indent_style = space
# END DO NOT EDIT

# DO NOT EDIT: ps1 convention
[*.ps1]
indent_size = tab
indent_style = tab
# END DO NOT EDIT

# DO NOT EDIT: yaml convention
[*.{yml,yaml}]
indent_size = 2
indent_style = space
# END DO NOT EDIT
